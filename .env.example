# ── Required: Login with Amazon (LwA) credentials ──────────────────────────
# Create an LwA security profile and request Amazon Ads API access:
# https://advertising.amazon.com/API/docs/en-us/onboarding/overview
AMAZON_ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxx
AMAZON_ADS_CLIENT_SECRET=your-client-secret
AMAZON_ADS_REFRESH_TOKEN=Atzr|your-refresh-token

# ── Required: API region ────────────────────────────────────────────────────
# NA = North America, EU = Europe/Middle East, FE = Far East (JP/AU/SG)
AMAZON_ADS_REGION=NA

# ── Optional: default profile scope ─────────────────────────────────────────
# If set, tools use this profile when no profileId argument is given.
# Find profile IDs with the get_profiles tool.
AMAZON_ADS_PROFILE_ID=

# ── Optional: tuning ────────────────────────────────────────────────────────
# Transport: stdio (Claude Desktop) or http (Docker / remote)
MCP_TRANSPORT=stdio
# Port for http transport
MCP_HTTP_PORT=3000
# Client-side rate limit, requests per second (Amazon throttles dynamically;
# this is a conservative client-side ceiling)
AMAZON_ADS_RATE_LIMIT_RPS=5
# Cache TTL for list/read responses, seconds (0 disables caching)
AMAZON_ADS_CACHE_TTL_SECONDS=60
# Max retry attempts for throttled/transient failures
AMAZON_ADS_MAX_RETRIES=4
# pino log level: trace|debug|info|warn|error (logs go to stderr, never stdout)
LOG_LEVEL=info
# Directory where download_report / amc_download_results may write files
REPORT_OUTPUT_DIR=./reports-output
